[Unit]
Description=WhatsApp Bot FastAPI Service
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/whatsapp-bot
ExecStart=/home/ubuntu/whatsapp-bot/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
